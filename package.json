{
  "name": "tg-subscription-bot",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --watch src/index.ts",
    "build": "tsc && tsc-alias && tsc-esm-fix && swc dist -d dist",
    "bundle": "rollup -c",
    "start": "node dist/src/index.js",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "introspect": "drizzle-kit introspect",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@grammyjs/menu": "^1.3.1",
    "@grammyjs/storage-redis": "^2.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.10.1",
    "date-fns": "^2.30.0",
    "dotenv": "^16.1.4",
    "drizzle-orm": "^1.0.0-beta.1-fd8bfcc",
    "esbuild": "^0.27.0",
    "grammy": "^1.16.0",
    "hono": "^3.0.0",
    "ioredis": "^5.3.2",
    "multer": "^3.0.0-alpha.1",
    "node-cron": "^4.2.1",
    "node-fetch": "^4.0.0-beta.4",
    "pg": "^8.11.0",
    "pino": "^8.0.0",
    "pino-pretty": "^10.0.0",
    "rollup": "^4.53.3",
    "swc": "^1.0.11",
    "tsc-alias": "^1.8.16",
    "tsc-esm-fix": "^3.1.2",
    "tslib": "^2.8.1",
    "zod": "^3.21.4"
  },
  "devDependencies": {
    "@types/pg": "^8.15.6",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "drizzle-kit": "^1.0.0-beta.1-fd8bfcc",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
